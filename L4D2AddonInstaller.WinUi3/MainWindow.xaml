<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="L4D2AddonInstaller.WinUi3.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:L4D2AddonInstaller.WinUi3.Services"
    mc:Ignorable="d"
    Title="L4D2AddonInstaller.WinUi3">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <ScrollViewer>
        <StackPanel Padding="16" Spacing="12">
            <TextBlock FontSize="22" FontWeight="SemiBold" Text="《求生之路2》附加组件安装器 - WinUI3" />

            <Expander Header="路径设置" IsExpanded="True">
                <StackPanel Spacing="8" Padding="0,8,0,0">
                    <TextBox Header="Steam 路径" Text="{Binding SteamPath, Mode=TwoWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="浏览 Steam" Command="{Binding BrowseSteamPathCommand}" />
                        <Button Content="自动检索 Steam" Command="{Binding DetectSteamPathCommand}" />
                    </StackPanel>

                    <TextBox Header="L4D2 路径" Text="{Binding GamePath, Mode=TwoWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="浏览 L4D2" Command="{Binding BrowseGamePathCommand}" />
                        <Button Content="自动检索 L4D2" Command="{Binding DetectGamePathCommand}" />
                        <Button Content="一键检索路径" Command="{Binding DetectAllPathCommand}" />
                    </StackPanel>
                </StackPanel>
            </Expander>

            <Expander Header="代号下载与安装" IsExpanded="True">
                <StackPanel Spacing="8" Padding="0,8,0,0">
                    <TextBox Header="下载代号" PlaceholderText="例如 1、231" Text="{Binding CodeName, Mode=TwoWay}" />
                    <TextBox Header="服务器信息" Text="{Binding ServerInfo}" IsReadOnly="True" />
                    <TextBox Header="控制台连接命令" Text="{Binding ConsoleCommand}" IsReadOnly="True" />
                    <CheckBox Content="安装完成后自动启动游戏" IsChecked="{Binding AutoStartGame, Mode=TwoWay}" />

                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding DownloadPercent}" />
                    <TextBlock Text="{Binding StatusMessage}" />
                    <TextBlock Text="{Binding DownloadPercent, StringFormat='下载进度：{0}%'}" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="获取服务器信息" Command="{Binding ResolveServerInfoCommand}" />
                        <Button Content="下载并安装" Command="{Binding InstallByCodeCommand}" />
                        <Button Content="取消下载" Command="{Binding CancelDownloadCommand}" IsEnabled="{Binding CanCancelDownload}" />
                        <Button Content="一键完成" Command="{Binding OneClickFinishAllCommand}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="启动 Steam" Command="{Binding StartSteamCommand}" />
                        <Button Content="启动游戏" Command="{Binding StartGameCommand}" />
                        <Button Content="打开压缩包下载目录" Command="{Binding OpenArchiveDownloadFolderCommand}" />
                    </StackPanel>
                </StackPanel>
            </Expander>

            <Expander Header="7-Zip 解压工具 (Modern)" IsExpanded="True">
                <StackPanel Spacing="8" Padding="0,8,0,0">
                    <TextBox Header="压缩包路径（多个用 ; 分隔）" Text="{Binding ArchivePaths, Mode=TwoWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="选择压缩包" Command="{Binding BrowseArchivesCommand}" />
                    </StackPanel>

                    <TextBox Header="7z.exe 路径" Text="{Binding SevenZipPath, Mode=TwoWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="浏览 7z.exe" Command="{Binding BrowseSevenZipCommand}" />
                        <Button Content="自动检索 7z" Command="{Binding DetectSevenZipCommand}" />
                        <Button Content="下载 7z 组件" Command="{Binding DownloadSevenZipCommand}" />
                    </StackPanel>

                    <TextBox Header="输出目录" Text="{Binding OutputDir, Mode=TwoWay}" />
                    <Button Content="浏览输出目录" Command="{Binding BrowseOutputDirCommand}" HorizontalAlignment="Left" />

                    <ComboBox Header="覆盖模式" ItemsSource="{Binding OverwriteModes}" SelectedItem="{Binding OverwriteMode, Mode=TwoWay}" />

                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding ExtractPercent}" />
                    <TextBlock Text="{Binding ExtractPercent, StringFormat='解压进度：{0}%'}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="开始解压" Command="{Binding ExtractArchivesCommand}" />
                        <Button Content="取消解压" Command="{Binding CancelExtractCommand}" />
                    </StackPanel>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</Window>
